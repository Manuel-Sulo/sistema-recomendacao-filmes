# ============================================================
# Sulo Movies — Environment Configuration
# Copy this file to .env and adjust for your setup
# ============================================================

# --- Database ---
# Instruções de Colaboração:
# - Se usares WAMP (Ex: User): DB_PORT=3306
# - Se usares XAMPP (Ex: Manuel-Sulo): DB_PORT=3307 ou 3306 (dependendo do painel XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=movie_recommender
DB_USER=root
DB_PASS=

# --- JWT Authentication ---
JWT_SECRET=movie_recommender_secret_key_2026_change_in_production
JWT_EXPIRY=86400

# --- TMDB API ---
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_URL=https://image.tmdb.org/t/p

# --- GROQ API (Llama 3 AI) ---
GROQ_API_KEY=your_groq_api_key_here

# --- OMDB API ---
OMDB_API_KEY=your_omdb_api_key_here
OMDB_BASE_URL=http://www.omdbapi.com

# --- Application ---
APP_ENV=development

# APP_URL varies by server:
#   WAMP:  http://localhost/srf-movies/backend/public
#   XAMPP: http://localhost/EngSof-lab4/backend/public
#   Note: The router auto-detects the base path, so any alias works.
APP_URL=http://localhost/srf-movies/backend/public

FRONTEND_URL=http://localhost:4200
